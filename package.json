{
  "name": "@cyanheads/eia-energy-mcp-server",
  "version": "0.2.1",
  "mcpName": "io.github.cyanheads/eia-energy-mcp-server",
  "description": "Browse and query the U.S. Energy Information Administration API v2 \u2014 electricity, petroleum, natural gas, coal, forecasts, and more via MCP. STDIO or Streamable HTTP.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "eia-energy-mcp-server": "dist/index.js"
  },
  "files": [
    "changelog/",
    "dist/",
    "README.md",
    "LICENSE",
    "CLAUDE.md",
    "Dockerfile",
    "server.json"
  ],
  "scripts": {
    "build": "bun run scripts/build.ts",
    "rebuild": "bun run scripts/clean.ts && bun run scripts/build.ts",
    "clean": "bun run scripts/clean.ts",
    "devcheck": "bun run scripts/devcheck.ts",
    "audit:refresh": "rm -f bun.lock && bun install && bun audit",
    "tree": "bun run scripts/tree.ts",
    "format": "biome check --write --unsafe .",
    "lint:mcp": "bun run scripts/lint-mcp.ts",
    "lint:packaging": "bun run scripts/lint-packaging.ts",
    "bundle": "bun run build && npx -y @anthropic-ai/mcpb pack . dist/eia-energy-mcp-server.mcpb",
    "changelog:build": "bun run scripts/build-changelog.ts",
    "changelog:check": "bun run scripts/build-changelog.ts --check",
    "list-skills": "bun run scripts/list-skills.ts",
    "test": "vitest run",
    "start": "node dist/index.js",
    "start:stdio": "MCP_TRANSPORT_TYPE=stdio node dist/index.js",
    "start:http": "MCP_TRANSPORT_TYPE=http node dist/index.js",
    "publish-mcp": "mcp-publisher login github -token \"$(security find-generic-password -a \"$USER\" -s mcp-publisher-github-pat -w)\" && mcp-publisher publish"
  },
  "keywords": [
    "eia",
    "energy",
    "energy-information-administration",
    "electricity",
    "petroleum",
    "natural-gas",
    "coal",
    "energy-data",
    "energy-api",
    "steo",
    "us-energy",
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "typescript",
    "bun",
    "ai-agent"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cyanheads/eia-energy-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/cyanheads/eia-energy-mcp-server/issues"
  },
  "homepage": "https://github.com/cyanheads/eia-energy-mcp-server#readme",
  "author": "cyanheads <casey@caseyjhand.com> (https://github.com/cyanheads/eia-energy-mcp-server#readme)",
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/cyanheads"
    },
    {
      "type": "buy_me_a_coffee",
      "url": "https://www.buymeacoffee.com/cyanheads"
    }
  ],
  "license": "Apache-2.0",
  "packageManager": "bun@1.3.0",
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=24.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@cyanheads/mcp-ts-core": "^0.9.6",
    "@duckdb/node-api": "^1.5.3-r.1",
    "fuse.js": "^7.3.0",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^25.9.1",
    "depcheck": "^1.4.7",
    "ignore": "^7.0.5",
    "tsc-alias": "^1.8.17",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
